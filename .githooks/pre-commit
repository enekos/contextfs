#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "${ROOT_DIR}"

# Unset the git env vars that get set while running hooks. Otherwise child
# processes that invoke `git init`/`git commit` in temp dirs (e.g. the
# internal/git and internal/enricher tests) recursively re-enter this hook
# with the main repo's GIT_DIR, which causes `git add -A` in the temp repo
# to stage deletion of every main-repo file.
unset GIT_DIR GIT_INDEX_FILE GIT_WORK_TREE GIT_OBJECT_DIRECTORY GIT_PREFIX

echo "[pre-commit] Checking fixture consistency..."
./scripts/check-fixtures.sh

echo "[pre-commit] Running Go checks..."
make check-go
